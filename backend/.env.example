# ---- Dash backend environment ----
# Copy to `.env` and fill in real values. Never commit `.env`.

# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dash?schema=public"

# API server port (optional; defaults to 3000).
PORT=3000

# Origin allowed by CORS — the Angular dev server (optional; defaults to :4200).
CORS_ORIGIN="http://localhost:4200"

# Secret used to sign JWTs (auth feature).
JWT_SECRET="change-me"

# 32-byte key for AES-256-GCM encryption of Reddit refresh tokens (base64 or hex).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="change-me-32-bytes-base64-or-hex"

# ---- Reddit API (per-account OAuth) ----
# Register a "web app" at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="dash/0.1 by <your-reddit-username>"
REDDIT_REDIRECT_URI="http://localhost:3000/api/reddit/callback"
