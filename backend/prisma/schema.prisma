// Dash Prisma schema — core entities for tracking Reddit karma-farming work.
// Skeleton scaffold: schema + `prisma generate` only. No migration is run yet
// (per CLAUDE.md, migrations are added deliberately, not during scaffolding).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Dash account role. Drives role-aware routing and guards.
enum UserRole {
  admin
  shiller
}

/// Health of a linked Reddit account, surfaced with semantic colors in the UI.
enum RedditAccountStatus {
  active
  banned
  suspended
  error
}

/// A Dash user. Shillers own 1..N linked Reddit accounts; admins oversee all.
model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  role           UserRole        @default(shiller)
  // Weekly quota targets, interpreted per owned Reddit account: each of a
  // shiller's accounts is expected to hit these comment/post counts each week.
  // The dashboard sums them across in-scope accounts to show quota progress.
  weeklyCommentQuota Int         @default(50)
  weeklyPostQuota    Int         @default(5)
  redditAccounts RedditAccount[]
  refreshTokens  RefreshToken[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

/// A persisted refresh-token grant. We store only a SHA-256 hash of the issued
/// token (never the token itself), so a DB leak cannot be replayed. Rotation on
/// refresh sets `revokedAt`; logout revokes the presented grant.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 of the raw refresh token; enables lookup + revocation
  expiresAt DateTime
  revokedAt DateTime? // set on rotation or logout; a non-null value invalidates the grant
  createdAt DateTime  @default(now())

  // Reason: refresh/logout look grants up by user; index keeps that cheap.
  @@index([userId])
}

/// A Reddit account a shiller tracks, identified by public username only. Comment
/// history is public, so Dash reads it with one shared service token (see
/// RedditService) rather than a per-account OAuth grant — no token is stored here.
model RedditAccount {
  id             String              @id @default(uuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  redditUsername String
  status         RedditAccountStatus @default(active)
  lastCheckedAt  DateTime?
  karmaSnapshots KarmaSnapshot[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // One entry per (shiller, reddit account) — prevents tracking duplicates.
  @@unique([userId, redditUsername])
}

/// A weekly karma baseline for a tracked account, powering the karma-trend
/// (this-week vs last-week) comparison. Karma is otherwise read live and never
/// stored; this table captures one immutable value per account per week — the
/// first karma seen that week (≈ the week-start baseline), written through on
/// dashboard load. Diffing consecutive weeks' baselines yields weekly karma gain.
model KarmaSnapshot {
  id         String        @id @default(uuid())
  accountId  String
  account    RedditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  weekStart  DateTime // Monday 00:00 (local) of the captured week
  karma      Int
  capturedAt DateTime      @default(now())

  // One baseline per (account, week); the write-through upsert relies on this.
  @@unique([accountId, weekStart])
  @@index([accountId])
}
